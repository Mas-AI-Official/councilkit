{
  "name": "councilkit",
  "version": "0.1.0",
  "description": "Claude Code plugin and bundled MCP server for local multi-model CLI orchestration",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "council-hub": "./bin/council-hub.js"
  },
  "files": [
