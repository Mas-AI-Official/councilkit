{
  "workers": {
    "codex": {
      "type": "cli",
      "enabled": true,
      "command": "codex",
      "role_tags": ["coding", "review", "general"],
      "cost_hint": "subscription",
      "privacy_mode": "remote",
      "priority": 10
    },
    "gemini": {
      "type": "cli",
      "enabled": true,
      "command": "gemini",
      "role_tags": ["research", "analysis", "general"],
      "cost_hint": "subscription",
      "privacy_mode": "remote",
      "priority": 20
    },
    "ollama": {
      "type": "cli",
      "enabled": true,
      "command": "ollama run llama3.1 \"{task}\"",
      "role_tags": ["local", "coding", "drafting", "general"],
      "cost_hint": "free",
      "privacy_mode": "local",
      "priority": 30
    }
  },
  "routing": {
    "default_mode": "council",
    "fallback_priority": ["ollama", "codex", "gemini"],
    "max_workers_per_task": 3,
    "prefer_local_for_sensitive_tasks": true,
    "prefer_subscription_before_api": true
  }
}
