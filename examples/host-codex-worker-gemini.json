{
  "active_host": "codex_cli",
  "hosts": {
    "codex_cli": {
      "type": "cli_host",
      "enabled": true,
      "command": "codex"
    }
  },
  "workers": {
    "gemini": {
      "type": "cli",
      "enabled": true,
      "command": "gemini",
