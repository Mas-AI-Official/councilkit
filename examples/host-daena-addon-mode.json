{
  "active_host": "daena",
  "hosts": {
    "daena": {
      "type": "mcp_host",
      "enabled": true,
      "notes": "Daena calls council-hub as orchestration middleware."
    }
  },
  "workers": {
    "codex": {
      "type": "cli",
      "enabled": true,
      "command": "codex",
      "role_tags": ["coding", "review", "general"],
      "cost_hint": "subscription",
      "privacy_mode": "remote",
      "priority": 10
    },
    "gemini": {
      "type": "cli",
      "enabled": true,
      "command": "gemini",
      "role_tags": ["research", "analysis", "general"],
      "cost_hint": "subscription",
      "privacy_mode": "remote",
      "priority": 20
    },
    "local": {
      "type": "cli",
      "enabled": true,
      "command": "python local_worker.py \"{task}\"",
      "role_tags": ["local", "general", "drafting"],
      "cost_hint": "free",
      "privacy_mode": "local",
      "priority": 30,
      "output_format": "auto"
    }
  },
  "discovery": {
    "enabled": false
  },
  "routing": {
    "default_mode": "council",
    "fallback_priority": [
      "codex",
      "gemini",
      "local"
    ],
    "allow_single_worker": true
  }
}
